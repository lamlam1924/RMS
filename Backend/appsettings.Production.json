{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedOrigins": [
    "https://yourdomain.com",
    "https://www.yourdomain.com"
  ],

  "FrontendUrl": "https://yourdomain.com",

  "ConnectionStrings": {
    "DefaultConnection": "Server=your-production-server;Database=RecruitmentDB;User Id=sa;Password=123;TrustServerCertificate=True"
  },

  "JWT": {
    "Secret": "YourProductionSecretKey_MustBeAtLeast32CharactersAndVerySecure!",
    "Issuer": "RMS-Backend-Production",
    "Audience": "RMS-Frontend-Production",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },

  "Google": {
    "ClientId": "your-production-google-client-id.apps.googleusercontent.com",
    "ClientSecret": "your-production-google-client-secret",
    "RedirectUri": "https://yourdomain.com/login"
  }
}
