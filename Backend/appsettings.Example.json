{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "AllowedOrigins": [
    "http://localhost:5173",
    "https://localhost:5173"
  ],

  "FrontendUrl": "http://localhost:5173",

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=RecruitmentDB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=False"
  },

  "JWT": {
    "Secret": "YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "RMS-Backend",
    "Audience": "RMS-Frontend",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },

  "Google": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
    "RedirectUri": "http://localhost:5173/login"
  },

  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUser": "your-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "FromEmail": "your-email@gmail.com",
    "FromName": "RMS Platform",
    "HREmail": "hr@company.com",
    "HRPhone": "0123456789"
  },

  "AppSettings": {
    "BaseUrl": "http://localhost:5173"
  }
}
